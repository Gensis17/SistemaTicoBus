@model IEnumerable<SistemaTicoBus.MODEL.Entidades.Pasajero>
@{
    Layout = null;
    ViewData["Title"] = "TicoBus - Registro de Pasajeros";
    var pasajeroEditar = ViewBag.PasajeroEditar as SistemaTicoBus.MODEL.Entidades.Pasajero;
    bool esEdicion = pasajeroEditar != null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
</head>
<body class="bg-[#f4f6f8] font-['Montserrat'] text-gray-900 min-h-screen flex">

    <aside class="hidden md:flex flex-col h-screen w-64 bg-white border-r border-gray-200 shadow-sm py-6 shrink-0">
        <div class="px-6 mb-6">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-[#006a62] font-bold">navigation</span>
                <h1 class="text-xl font-bold text-gray-800">TicoBus</h1>
            </div>
            <p class="text-xs text-gray-500">Panel de Operador</p>
        </div>

        <div class="px-5 mb-2">
            <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Operación</p>
        </div>

        <nav class="flex-1 px-3 space-y-1">
            <a class="flex items-center gap-3 text-gray-600 hover:bg-gray-100 rounded-lg px-3 py-2.5 transition-colors" href="/Account/ChoferDashboard">
                <span class="material-symbols-outlined text-gray-400">account_circle</span>
                <span class="text-sm font-medium">Mi Perfil</span>
            </a>
            <a class="flex items-center gap-3 bg-[#e0f2f1] text-[#004d40] font-semibold rounded-lg px-3 py-2.5" href="/Pasajeros/ListadoPasajeros">
                <span class="material-symbols-outlined text-[#006a62]">person_add</span>
                <span class="text-sm">Registrar Pasajero</span>
            </a>
            <a class="flex items-center gap-3 text-gray-600 hover:bg-gray-100 rounded-lg px-3 py-2.5 transition-colors" href="/Rutas/Index">
                <span class="material-symbols-outlined text-gray-400">explore</span>
                <span class="text-sm font-medium">Catálogo de Rutas</span>
            </a>
            <a class="flex items-center gap-3 text-gray-600 hover:bg-gray-100 rounded-lg px-3 py-2.5 transition-colors" href="/Account/ChangePassword">
                <span class="material-symbols-outlined text-gray-400">lock_reset</span>
                <span class="text-sm font-medium">Cambiar clave</span>
            </a>
            <a class="flex items-center gap-3 text-gray-600 hover:bg-gray-100 rounded-lg px-3 py-2.5 transition-colors" href="#">
                <span class="material-symbols-outlined text-gray-400">directions_bus</span>
                <span class="text-sm font-medium">Mis Viajes</span>
            </a>
        </nav>

        <div class="px-4 border-t border-gray-200 pt-4">
            <a class="flex items-center gap-3 text-red-600 hover:bg-red-50 rounded-lg px-3 py-2 transition-colors" href="/Account/Logout">
                <span class="material-symbols-outlined">logout</span>
                <span class="text-sm font-medium">Cerrar Sesión</span>
            </a>
        </div>
    </aside>

    <div class="flex-1 flex flex-col min-w-0 h-screen overflow-hidden">
        <header class="bg-[#0b192c] text-white shadow-md flex justify-between items-center px-8 py-4 z-10">
            <span class="text-lg font-bold tracking-wide">Consola TicoBus</span>
            <span class="text-xs bg-white/10 px-3 py-1 rounded-full">Rol: Chofer</span>
        </header>

        <div class="flex-1 overflow-y-auto p-6">
            <div class="text-xs font-bold text-gray-400 tracking-wider mb-4">CHOFER ➔ REGISTRAR PASAJERO</div>

            @if (TempData["MensajeExito"] != null)
            {
                <div class="mb-4 flex items-start gap-3 p-4 bg-green-50 border border-green-200 text-green-800 text-sm rounded-xl shadow-sm">
                    <span class="material-symbols-outlined text-green-600 mt-0.5">check_circle</span>
                    <span>@TempData["MensajeExito"]</span>
                </div>
            }
            @if (TempData["MensajeError"] != null)
            {
                <div class="mb-4 flex items-start gap-3 p-4 bg-red-50 border border-red-200 text-red-800 text-sm rounded-xl shadow-sm">
                    <span class="material-symbols-outlined text-red-500 mt-0.5">error</span>
                    <span>@TempData["MensajeError"]</span>
                </div>
            }

            <div class="flex gap-6 items-start">

                <div class="w-72 shrink-0">
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
                        <div class="border-b border-gray-100 pb-3 mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-[#006a62] text-base">@(esEdicion ? "edit" : "person_add")</span>
                            <h3 class="font-bold text-gray-800 text-sm">
                                @(esEdicion ? "Modificar Pasajero" : "Registrar Nuevo Pasajero")
                            </h3>
                        </div>

                        <form action="/Pasajeros/@(esEdicion ? "EditarPasajeroGuardar" : "RegistrarPasajeroGuardar")" method="post" class="space-y-3">
                            @if (esEdicion)
                            {
                                <input type="hidden" name="idOriginal" value="@ViewBag.IdOriginal" />
                            }

                            <div>
                                <label class="block font-bold text-gray-500 mb-1 uppercase tracking-wider text-[10px]">Identificación / Cédula</label>
                                <input type="text" name="Identificacion" required placeholder="Ej: 1-1234-5678"
                                       value="@(esEdicion ? pasajeroEditar.Identificacion : "")"
                                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#006a62] focus:border-[#006a62] text-gray-800 text-xs font-medium" />
                            </div>
                            <div>
                                <label class="block font-bold text-gray-500 mb-1 uppercase tracking-wider text-[10px]">Nombre</label>
                                <input type="text" name="Nombre" required placeholder="Nombre del pasajero"
                                       value="@(esEdicion ? pasajeroEditar.Nombre : "")"
                                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#006a62] focus:border-[#006a62] text-gray-800 text-xs font-medium" />
                            </div>
                            <div>
                                <label class="block font-bold text-gray-500 mb-1 uppercase tracking-wider text-[10px]">Apellidos</label>
                                <input type="text" name="Apellidos" required placeholder="Apellidos del pasajero"
                                       value="@(esEdicion ? pasajeroEditar.Apellidos : "")"
                                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#006a62] focus:border-[#006a62] text-gray-800 text-xs font-medium" />
                            </div>
                            <div>
                                <label class="block font-bold text-gray-500 mb-1 uppercase tracking-wider text-[10px]">Correo Electrónico</label>
                                <input type="email" name="Correo" required placeholder="correo@ejemplo.com"
                                       value="@(esEdicion ? pasajeroEditar.Correo : "")"
                                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#006a62] focus:border-[#006a62] text-gray-800 text-xs font-medium" />
                            </div>

                            <div class="pt-2 flex gap-2">
                                @if (esEdicion)
                                {
                                    <a href="/Pasajeros/ListadoPasajeros"
                                       class="flex-1 text-center py-2 border border-gray-300 text-gray-700 font-bold rounded-lg hover:bg-gray-50 transition text-xs">
                                        Cancelar
                                    </a>
                                }
                                <button type="submit"
                                        class="flex-1 py-2 bg-[#006a62] hover:bg-[#004d40] text-white font-bold rounded-lg shadow transition text-xs">
                                    @(esEdicion ? "Guardar Cambios" : "Registrar")
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="flex-1 min-w-0 space-y-4">
                    <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-200">
                        <form action="/Pasajeros/ListadoPasajeros" method="get" class="flex gap-2">
                            <input type="text" name="buscarNombre" value="@ViewBag.Busqueda"
                                   placeholder="Buscar pasajeros por nombre..."
                                   class="flex-1 px-4 py-2 bg-gray-50 border border-gray-300 rounded-lg text-xs focus:ring-2 focus:ring-[#006a62] focus:outline-none" />
                            <button type="submit" class="bg-gray-800 hover:bg-gray-950 text-white font-bold text-xs px-5 py-2 rounded-lg transition">Buscar</button>
                            @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string))
                            {
                                <a href="/Pasajeros/ListadoPasajeros" class="bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold text-xs px-4 py-2 rounded-lg transition flex items-center">Limpiar</a>
                            }
                        </form>
                    </div>

                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                        <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
                            <h3 class="font-bold text-gray-700 text-sm">Pasajeros registrados</h3>
                            <span class="text-xs text-gray-400 font-medium">@Model.Count() resultado(s)</span>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left text-xs">
                                <thead>
                                    <tr class="bg-gray-50 border-b border-gray-200 text-gray-500 font-bold uppercase tracking-wider">
                                        <th class="px-5 py-3 whitespace-nowrap">Cédula</th>
                                        <th class="px-5 py-3 whitespace-nowrap">Nombre</th>
                                        <th class="px-5 py-3 whitespace-nowrap">Apellidos</th>
                                        <th class="px-5 py-3 whitespace-nowrap">Correo</th>
                                        <th class="px-5 py-3 whitespace-nowrap text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100 text-gray-700 font-medium">
                                    @if (!Model.Any())
                                    {
                                        <tr>
                                            <td colspan="5" class="px-5 py-8 text-center text-gray-400 font-semibold">No hay pasajeros registrados.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var p in Model)
                                        {
                                            <tr class="hover:bg-gray-50 transition">
                                                <td class="px-5 py-3 font-bold text-gray-900 whitespace-nowrap">@p.Identificacion</td>
                                                <td class="px-5 py-3 whitespace-nowrap">@p.Nombre</td>
                                                <td class="px-5 py-3 whitespace-nowrap">@p.Apellidos</td>
                                                <td class="px-5 py-3 text-[#006a62] font-semibold whitespace-nowrap">@p.Correo</td>
                                                <td class="px-5 py-3 text-center whitespace-nowrap">
                                                    <a href="/Pasajeros/ListadoPasajeros?identificacionEditar=@p.Identificacion&buscarNombre=@ViewBag.Busqueda"
                                                       class="inline-flex items-center gap-1 bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-1.5 rounded-md border border-amber-200 font-bold transition">
                                                        <span class="material-symbols-outlined text-sm">edit</span>
                                                        Editar
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

</body>
</html>
