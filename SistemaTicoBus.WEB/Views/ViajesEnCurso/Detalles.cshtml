@model SistemaTicoBus.MODEL.Entidades.Viaje
@{
    ViewData["Title"] = "Panel de Control de Viaje";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Volver al Monitoreo</a>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card border-primary shadow-sm h-100">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="card-title mb-0"><i class="bi bi-calculator"></i> Estado Financiero</h5>
                </div>
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="mb-3">
                            <label class="text-muted small d-block">Pasajeros a Bordo</label>
                            <span class="fs-4 fw-bold text-dark">@ViewBag.PasajerosEmbarcados</span>
                        </div>
                        <div class="mb-3">
                            <label class="text-muted small d-block">Asientos Disponibles</label>
                            <span class="fs-4 fw-bold text-warning">@ViewBag.AsientosDisponibles</span>
                        </div>
                        <hr />
                        <div class="p-3 bg-light rounded text-success text-center mb-4 border border-success-subtle">
                            <label class="small d-block text-uppercase fw-bold">Total Recaudado</label>
                            <span class="fs-3 fw-bold">₡@String.Format("{0:N2}", ViewBag.TotalRecaudado)</span>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <a asp-action="Reservar" asp-route-id="@Model.IdViaje" class="btn btn-success fw-bold py-2">
                            <i class="bi bi-plus-lg"></i> Asignar Asiento
                        </a>
                        <button class="btn btn-danger fw-bold py-2" data-bs-toggle="modal" data-bs-target="#modalCierre">
                            <i class="bi bi-flag-fill"></i> Finalizar Viaje
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="card-title mb-0"><i class="bi bi-people-fill"></i> Manifiesto de Pasajeros Abordados</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-3">Pasajero</th>
                                    <th>Cédula / Identificación</th>
                                    <th class="text-center">Asiento</th>
                                    <th>Monto Pagado</th>
                                    <th class="text-center">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var reserva in Model.Reservas.OrderBy(r => r.NumeroAsiento))
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold">@reserva.Pasajero?.Nombre @reserva.Pasajero?.Apellidos</td>
                                        <td>@reserva.Pasajero?.Identificacion</td>
                                        <td class="text-center"><span class="badge bg-dark px-2 py-1">#@reserva.NumeroAsiento</span></td>
                                        <td class="text-success fw-bold">₡@String.Format("{0:N2}", reserva.MontoPagado)</td>
                                        <td class="text-center">
                                            <form asp-action="CancelarReserva" method="post" onsubmit="return confirm('¿Seguro que desea liberar este asiento y eliminar la reserva?');">
                                                <input type="hidden" name="idReserva" value="@reserva.IdReserva" />
                                                <input type="hidden" name="idViaje" value="@Model.IdViaje" />
                                                <button type="submit" class="btn btn-link text-danger p-0 m-0 border-0"><i class="bi bi-trash3-fill fs-5"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                                @if (!Model.Reservas.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-5">No hay registros de tiquetes vendidos o asientos asignados para este viaje.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalCierre" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Arqueo de Caja y Cierre de Viaje</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p class="fs-6">Verifique los montos consolidados antes de consolidar el viaje a estado <strong>Completado</strong>:</p>
                <div class="card bg-light p-3 mb-3 border-0">
                    <h2 class="text-success mb-1 fw-bold">₡@String.Format("{0:N2}", ViewBag.TotalRecaudado)</h2>
                    <span class="text-muted small">Monto Total en Colones</span>
                    <div class="mt-2 text-dark">Pasajeros Registrados: <strong>@ViewBag.PasajerosEmbarcados</strong></div>
                </div>
                <p class="text-danger small mb-0">⚠️ Nota: Una vez cerrado el viaje, no se podrán añadir nuevos abordajes ni reversar reservas.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Mantener Abierto</button>
                <form asp-action="FinalizarViaje" method="post">
                    <input type="hidden" name="idViaje" value="@Model.IdViaje" />
                    <button type="submit" class="btn btn-danger fw-bold">Confirmar y Cerrar Operación</button>
                </form>
            </div>
        </div>
    </div>
</div>
