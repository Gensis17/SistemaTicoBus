@model IEnumerable<SistemaTicoBus.MODEL.Entidades.Viaje>
@{
    ViewData["Title"] = "Viajes en Curso";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-bus-front text-primary"></i> Monitoreo de Viajes en Curso</h2>
        <span class="badge bg-success p-2 fs-6">Operaciones en Tiempo Real</span>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm">@TempData["Error"]</div>
    }
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success shadow-sm">@TempData["Exito"]</div>
    }

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th># Viaje</th>
                        <th>Ruta Destino</th>
                        <th>Placa Unidad</th>
                        <th>Salida</th>
                        <th>Ocupación de la Unidad</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var viaje in Model)
                    {
                        int ocupados = viaje.Reservas?.Count ?? 0;
                        int capacidad = viaje.Unidad?.CapacidadPasajeros ?? 0;
                        double porcentaje = capacidad > 0 ? ((double)ocupados / capacidad) * 100 : 0;
                        
                        <tr>
                            <td><strong>@viaje.IdViaje</strong></td>
                            <td>@viaje.Ruta?.Nombre</td>
                            <td><span class="badge bg-secondary px-2 py-1">@viaje.Unidad?.Placa</span></td>
                            <td>@viaje.FechaHoraSalida.ToString("dd/MM/yyyy hh:mm tt")</td>
                            <td style="width: 30%;">
                                <div class="progress" style="height: 22px; border-radius: 4px;">
                                    <div class="progress-bar bg-info text-dark fw-bold" role="progressbar" style="width: @porcentaje%;">
                                        @ocupados / @capacidad Asientos
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <a asp-action="Detalles" asp-route-id="@viaje.IdViaje" class="btn btn-primary btn-sm rounded">
                                    <i class="bi bi-gear-fill"></i> Panel de Control
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="bi bi-info-circle fs-3 d-block mb-2"></i> No se registran viajes con estado "En Curso" en este momento.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>