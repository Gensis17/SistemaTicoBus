@{
    ViewData["Title"] = "Emitir Tiquete";
    var viaje = ViewBag.Viaje as SistemaTicoBus.MODEL.Entidades.Viaje;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="card-title mb-0"><i class="bi bi-ticket-perforated-fill"></i> Emitir Tiquete / Reservar Asiento</h5>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-secondary mb-4 border-0">
                        <div class="row small text-dark">
                            <div class="col-6"><strong>Destino:</strong> @viaje?.Ruta?.Nombre</div>
                            <div class="col-6 text-end"><strong>Tarifa:</strong> ₡@String.Format("{0:N2}", viaje?.Ruta?.PrecioBase)</div>
                        </div>
                    </div>

                    <form asp-action="Reservar" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" name="idViaje" value="@viaje?.IdViaje" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Seleccione el Pasajero</label>
                            <select name="idPasajero" class="form-select" asp-items="ViewBag.Pasajeros" required>
                                <option value="">-- Buscar Pasajero por Nombre --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Número de Asiento (Rango: 1 - @viaje?.Unidad?.CapacidadPasajeros)</label>
                            <input type="number" name="numeroAsiento" class="form-control" min="1" max="@viaje?.Unidad?.CapacidadPasajeros" placeholder="Ej: 12" required />
                            <div class="form-text">Asigne un asiento físico disponible dentro de la unidad de transporte.</div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-action="Detalles" asp-route-id="@viaje?.IdViaje" class="btn btn-light">Cancelar</a>
                            <button type="submit" class="btn btn-success px-4 fw-bold">Procesar Abordaje</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}