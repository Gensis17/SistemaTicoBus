<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicoBus</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <div class="container-fluid p-0">

        <div class="row g-0 top-header align-items-center shadow-sm">
            <div class="col-6 d-flex align-items-center">
                <span class="fw-bold" style="font-size: 1.1rem;">TicoBus</span>
                <span class="mx-3 text-secondary">|</span>
                <span class="small text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                    Consola de Operador
                </span>
            </div>
            <div class="col-6 text-end d-flex align-items-center justify-content-end">
                <i class="bi bi-bell me-4" style="font-size: 1.1rem; cursor: pointer;"></i>
                <div class="dropdown">
                    <button class="btn btn-link text-white text-decoration-none dropdown-toggle p-0 small d-flex align-items-center"
                            type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-2" style="font-size: 1.2rem;"></i>
                        @Context.Session.GetString("NombreUsuario")
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="row g-0">

            <div class="col-md-3 col-lg-2 p-3 sidebar d-flex flex-column justify-content-between">
                <div>
                    <div class="mb-4 px-2">
                        <h2 class="brand-title m-0">TicoBus</h2>
                        <span class="text-muted" style="font-size: 0.8rem;">Consola de Operador</span>
                    </div>
                    <div class="mb-2 px-2">
                        <span class="section-title">Administración</span>
                    </div>
                    <ul class="nav flex-column mb-4">
                        @if (Context.Session.GetString("Rol") == "Administrador")
                        {
                            <li class="nav-item">
                                <a asp-controller="Choferes" asp-action="Index"
                                   class="nav-link @(ViewData["Seccion"]?.ToString() == "Choferes" ? "active" : "")">
                                    <i class="bi bi-person-video2 me-3"></i> Gestión de Choferes
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="AdminDashboard"
                               class="nav-link @(ViewData["Seccion"]?.ToString() == "Rutas" ? "active" : "")">
                                <i class="bi bi-signpost-split me-3"></i> Catálogo de Rutas
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Unidad" asp-action="Index"
                               class="nav-link @(ViewData["Seccion"]?.ToString() == "Unidades" ? "active" : "")">
                                <i class="bi bi-bus-front me-3"></i> Catálogo de Unidades
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Viajes" asp-action="Index"
                               class="nav-link @(ViewData["Seccion"]?.ToString() == "Viajes" ? "active" : "")">
                                <i class="bi bi-calendar3 me-3"></i> Gestión de Viajes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="ViajesCancelados" asp-action="Index"
                               class="nav-link @(ViewData["Seccion"]?.ToString() == "ViajesCancelados" ? "active" : "")">
                                <i class="bi bi-calendar-x me-3"></i> Viajes Cancelados
                            </a>
                        </li>
                    </ul>
                </div>
                <div>
                    <hr class="text-muted">
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Logout" class="nav-link text-danger">
                                <i class="bi bi-box-arrow-right me-3"></i> Cerrar Sesión
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="col-md-9 col-lg-10 main-content">
                @if (TempData["Exito"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                        <i class="bi bi-check-circle me-2"></i> @TempData["Exito"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>