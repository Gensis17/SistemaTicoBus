@model IEnumerable<SistemaTicoBus.WEB.Models.ChoferViewModel>

@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Gestión de Choferes";
    ViewData["Seccion"] = "Choferes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <small class="text-muted text-uppercase fw-semibold">Administración / Personal</small>
        <h1 class="fw-bold text-dark mb-0">Gestión de Choferes</h1>
    </div>
    <button class="btn btn-primario d-flex align-items-center gap-2"
            data-bs-toggle="modal" data-bs-target="#modalAgregarChofer">
        <i class="bi bi-plus-circle"></i> Registrar Chofer
    </button>
</div>

<div class="dashboard-card mb-4">
    <form asp-controller="Choferes" asp-action="Index" method="get">
        <div class="row align-items-center g-2">
            <div class="col-md-10">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-0 text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text"
                           name="busqueda"
                           class="form-control border-0 bg-transparent"
                           placeholder="Buscar chofer por nombre..."
                           value="@ViewBag.Busqueda" />
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-secundario w-100">Buscar</button>
            </div>
        </div>
    </form>
</div>

<div class="dashboard-card">
    <h5 class="fw-bold text-dark mb-4">Listado de Choferes</h5>
    <div class="table-responsive">
        <table class="table tabla-dashboard align-middle mb-0">
            <thead>
                <tr>
                    <th class="border-0 py-3">Identificación</th>
                    <th class="border-0 py-3">Nombre Completo</th>
                    <th class="border-0 py-3">Correo</th>
                    <th class="border-0 py-3">Usuario</th>
                    <th class="border-0 py-3 text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var chofer in Model)
                    {
                        <tr>
                            <td class="fw-bold">@chofer.Identificacion</td>
                            <td>@chofer.Nombre @chofer.Apellidos</td>
                            <td>@chofer.Correo</td>
                            <td><span class="text-muted">@chofer.NombreUsuario</span></td>
                            <td class="text-end">
                                <button type="button"
                                        class="btn btn-sm btn-outline-warning border-0"
                                        title="Editar"
                                        onclick="prepararEdicion('@chofer.Identificacion', '@chofer.Nombre', '@chofer.Apellidos', '@chofer.Correo')">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <form asp-controller="Choferes" asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@chofer.Identificacion" />
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger border-0"
                                            title="Eliminar"
                                            onclick="return confirm('¿Seguro que deseas eliminar al chofer @chofer.Nombre?')">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">
                            No se encontraron choferes que coincidan con la búsqueda.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalAgregarChofer" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius: 1rem;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Registrar Nuevo Chofer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-controller="Choferes" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Identificación</label>
                        <input type="text" name="Identificacion" class="form-control" placeholder="1-1111-1111" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" name="Nombre" class="form-control" placeholder="Nombre del chofer" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Apellidos</label>
                        <input type="text" name="Apellidos" class="form-control" placeholder="Apellidos del chofer" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Correo electrónico</label>
                        <input type="email" name="Correo" class="form-control" placeholder="correo@ejemplo.com" required />
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primario">Guardar Chofer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEditarChofer" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius: 1rem;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Editar Chofer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formEditar" asp-controller="Choferes" asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="editIdOriginal" name="id" />
                    <div class="mb-3">
                        <label class="form-label">Identificación</label>
                        <input type="text" id="editIdentificacion" name="Identificacion" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" id="editNombre" name="Nombre" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Apellidos</label>
                        <input type="text" id="editApellidos" name="Apellidos" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Correo electrónico</label>
                        <input type="email" id="editCorreo" class="form-control" disabled />
                        <small class="text-muted">El correo no se puede modificar.</small>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primario">Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function prepararEdicion(id, nombre, apellidos, correo) {
            document.getElementById('editIdOriginal').value = id;
            document.getElementById('editIdentificacion').value = id;
            document.getElementById('editNombre').value = nombre;
            document.getElementById('editApellidos').value = apellidos;
            document.getElementById('editCorreo').value = correo;
            new bootstrap.Modal(document.getElementById('modalEditarChofer')).show();
        }
    </script>
}