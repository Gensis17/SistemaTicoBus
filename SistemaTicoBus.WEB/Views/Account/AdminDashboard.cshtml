@model SistemaTicoBus.WEB.Models.AdminDashboardViewModel
@using Microsoft.AspNetCore.Http
@{
    Layout = null;
    string busquedaActual = ViewBag.BusquedaActual as string ?? "";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Consola de Operador - TicoBus</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

    <style>
            body {
                background-color: #f4f6f8;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                font-size: 0.875rem;
            }

            .sidebar {
                background-color: #ffffff;
                min-height: 100vh;
                border-right: 1px solid #e9ecef;
            }

                .sidebar .brand-title {
                    color: #1a2530;
                    font-size: 1.25rem;
                    font-weight: 700;
                }

                .sidebar .section-title {
                    font-size: 0.7rem;
                    text-transform: uppercase;
                    letter-spacing: 0.05em;
                    color: #9097a3;
                    font-weight: 700;
                }

                .sidebar .nav-link {
                    color: #5a6578;
                    font-weight: 500;
                    font-size: 0.82rem;
                    padding: 0.65rem 1rem;
                    border-radius: 0.5rem;
                    margin-bottom: 0.2rem;
                    display: flex;
                    align-items: center;
                    text-decoration: none;
                }

                    .sidebar .nav-link.active {
                        background-color: #e8f7f2;
                        color: #0f7654;
                        font-weight: 600;
                    }

                    .sidebar .nav-link:hover:not(.active) {
                        background-color: #f8f9fa;
                        color: #1a2530;
                    }

            .btn-mint-action {
                background-color: #00664f;
                color: white;
                border-radius: 0.5rem;
                font-weight: 600;
                font-size: 0.82rem;
                padding: 0.65rem;
                border: none;
            }

            .top-header {
                background-color: #112233;
                color: white;
                padding: 0.65rem 1.5rem;
            }

            .search-box-container {
                background-color: #ffffff;
                border-radius: 0.75rem;
                border: 1px solid #e9ecef;
            }

            .custom-dashboard-card {
                background: #ffffff;
                border-radius: 1rem;
                border: 1px solid #e9ecef;
                padding: 1.25rem;
            }

            .btn-register {
                background-color: #0f3460;
                color: white;
                font-weight: 600;
                font-size: 0.82rem;
                border-radius: 0.5rem;
                padding: 0.65rem;
                border: none;
            }

                .btn-register:hover {
                    background-color: #0a2342;
                    color: white;
                }

            .table-routes th {
                background-color: #f8f9fa;
                color: #5a6578;
                font-weight: 600;
                text-transform: uppercase;
                font-size: 0.72rem;
            }

            .table-routes td {
                font-size: 0.82rem;
            }

            .form-label {
                font-size: 0.75rem;
            }

            .form-control, .form-select {
                font-size: 0.82rem;
            }

            h4.fs-5 {
                font-size: 0.95rem !important;
            }
    </style>
</head>
<body>

    <div class="container-fluid p-0">
        <!-- Header -->
        <div class="row g-0 top-header align-items-center shadow-sm">
            <div class="col-6 d-flex align-items-center">
                <span class="fw-bold" style="font-size: 1rem;">TicoBus</span>
                <span class="mx-3 text-secondary">|</span>
                <span class="text-muted text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.05em;">Consola de Operador</span>
            </div>
            <div class="col-6 text-end d-flex align-items-center justify-content-end">
                <i class="bi bi-bell me-4" style="cursor: pointer; font-size: 1rem;"></i>
                <div class="dropdown">
                    <button class="btn btn-link text-white text-decoration-none dropdown-toggle p-0 d-flex align-items-center" style="font-size: 0.82rem;" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-2" style="font-size: 1.1rem;"></i> @Model.NombreCompleto
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")"><i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="row g-0">
            <!-- Sidebar -->
            <div class="col-md-3 col-lg-2 p-3 sidebar d-flex flex-column justify-content-between">
                <div>
                    <div class="mb-4 px-2">
                        <h2 class="brand-title m-0">TicoBus</h2>
                        <span class="text-muted" style="font-size: 0.75rem;">Consola de Operador</span>
                    </div>
                    <div class="mb-3 px-2">
                        <span class="section-title">Administración</span>
                    </div>
                    <ul class="nav flex-column mb-4">
                        <li class="nav-item"><a href="@Url.Action("Index", "Choferes")" class="nav-link"><i class="bi bi-person-video2 me-3"></i> Gestión de Choferes</a></li>
                        <li class="nav-item"><a href="@Url.Action("AdminDashboard", "Account")" class="nav-link active"><i class="bi bi-signpost-split me-3"></i> Catálogo de Rutas</a></li>
                        <li class="nav-item"><a href="@Url.Action("Index", "Unidad")" class="nav-link"><i class="bi bi-bus-front me-3"></i> Catálogo de Unidades</a></li>
                        <li class="nav-item"><a href="#" class="nav-link"><i class="bi bi-calendar3 me-3"></i> Gestión de Viajes</a></li>
                        <li class="nav-item"><a href="#" class="nav-link"><i class="bi bi-calendar-x me-3"></i> Viajes Cancelados</a></li>
                    </ul>
                    <div class="px-2 mb-4">
                        <button class="btn btn-mint-action w-100 d-flex align-items-center justify-content-center">
                            <i class="bi bi-plus-circle me-2"></i> Nuevo Trayecto
                        </button>
                    </div>
                </div>
                <div>
                    <hr class="text-muted">
                    <ul class="nav flex-column">
                        <li class="nav-item"><a href="#" class="nav-link text-muted"><i class="bi bi-gear me-3"></i> Ajustes</a></li>
                        <li class="nav-item"><a href="@Url.Action("Logout", "Account")" class="nav-link text-danger"><i class="bi bi-box-arrow-right me-3"></i> Cerrar Sesión</a></li>
                    </ul>
                </div>
            </div>

            <div class="col-md-9 col-lg-10 p-4" style="background-color: #f4f6f8;">

                <div class="search-box-container p-3 mb-4 shadow-sm">
                    <form action="/Account/AdminDashboard" method="get">
                        <div class="row align-items-center g-2">
                            <div class="col">
                                <div class="input-group">
                                    <span class="input-group-text bg-transparent border-0 text-muted"><i class="bi bi-search"></i></span>
                                    <input type="text" name="buscar" id="inputBuscar" class="form-control border-0 bg-transparent"
                                           placeholder="Buscar rutas por nombre, origen o destino..."
                                           value="@busquedaActual" />
                                </div>
                            </div>
                            <div class="col-auto d-flex gap-2">
                                <button type="submit" class="btn btn-dark fw-semibold py-2 px-4" style="border-radius: 0.5rem; font-size: 0.82rem;">Buscar</button>
                                @if (!string.IsNullOrEmpty(busquedaActual))
                                {
                                    <a href="/Account/AdminDashboard" class="btn btn-outline-secondary fw-semibold py-2 px-3" style="border-radius: 0.5rem; font-size: 0.82rem;">
                                        <i class="bi bi-x-lg me-1"></i>Limpiar
                                    </a>
                                }
                            </div>
                        </div>
                    </form>
                </div>

                <div class="row g-4">
                    @if (Context.Session.GetString("Rol") == "Administrador")
                    {
                        <div class="col-xl-4 col-lg-5">
                            <div class="custom-dashboard-card shadow-sm">
                                <h4 id="formTitle" class="fs-5 fw-bold mb-3 text-dark">Agregar Nueva Ruta</h4>

                                <form id="formRuta" action="/Rutas/Crear" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" id="inputId" />
                                    <input type="hidden" name="duracion" id="inputDuracionHidden" />

                                    <div class="mb-2">
                                        <label class="form-label text-secondary fw-semibold">Nombre</label>
                                        <input type="text" name="nombre" id="inputNombre" class="form-control" required />
                                    </div>
                                    <div class="mb-2">
                                        <label class="form-label text-secondary fw-semibold">Origen</label>
                                        <input type="text" name="origen" id="inputOrigen" class="form-control" required />
                                    </div>
                                    <div class="mb-2">
                                        <label class="form-label text-secondary fw-semibold">Destino</label>
                                        <input type="text" name="destino" id="inputDestino" class="form-control" required />
                                    </div>
                                    <div class="row g-2 mb-3">
                                        <div class="col-6">
                                            <label class="form-label text-secondary fw-semibold">Duración (hh:mm)</label>
                                            <input type="text" id="inputDuracionVisible" class="form-control"
                                                   placeholder="04:30" required
                                                   pattern="^\d{1,2}:\d{2}$"
                                                   title="Formato hh:mm, ejemplo: 01:30" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label text-secondary fw-semibold">Precio Base (₡)</label>
                                            <!-- min="1" impide precios negativos o cero -->
                                            <input type="number" step="1" min="1" name="precioBase" id="inputPrecio"
                                                   class="form-control" required />
                                        </div>
                                    </div>
                                    <button type="submit" id="btnSubmit" class="btn btn-register w-100 shadow-sm">
                                        Registrar Ruta
                                    </button>
                                    <button type="button" id="btnCancelar" class="btn btn-outline-secondary w-100 mt-2" style="font-size:0.82rem; display:none;" onclick="cancelarEdicion()">
                                        Cancelar edición
                                    </button>
                                </form>
                            </div>
                        </div>
                    }

                    <!-- Tabla de rutas -->
                    <div class="col-xl-8 col-lg-7">
                        <div class="custom-dashboard-card shadow-sm">
                            <h4 class="fs-5 fw-bold mb-3 text-dark">Listado de Rutas</h4>
                            <div class="table-responsive">
                                <table class="table table-routes align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th class="border-0 py-3">ID / Nombre</th>
                                            <th class="border-0 py-3">Origen</th>
                                            <th class="border-0 py-3">Destino</th>
                                            <th class="border-0 py-3">Duración</th>
                                            <th class="border-0 py-3">Precio Base</th>
                                            <th class="border-0 py-3 text-end">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model?.Rutas != null && Model.Rutas.Any())
                                        {
                                            foreach (var ruta in Model.Rutas)
                                            {
                                                <tr>
                                                    <td class="py-3">
                                                        <span class="fw-bold text-dark">@ruta.Nombre</span>
                                                    </td>
                                                    <td class="text-secondary">@ruta.Origen</td>
                                                    <td class="text-secondary">@ruta.Destino</td>
                                                    <td>
                                                        <span class="badge bg-light text-dark border px-2 py-1">
                                                            <i class="bi bi-clock me-1 text-muted"></i>
                                                            @ruta.DuracionEstimada.ToString(@"hh\:mm") h
                                                        </span>
                                                    </td>
                                                    <td class="fw-bold text-success">₡@ruta.PrecioBase.ToString("N0")</td>
                                                    <td class="text-end py-3">
                                                        @if (Context.Session.GetString("Rol") == "Administrador")
                                                        {
                                                            <button type="button" class="btn btn-sm btn-outline-warning border-0"
                                                                    onclick="editarRuta(@ruta.Id, '@Html.Raw(ruta.Nombre.Replace("'", "\'"))', '@Html.Raw(ruta.Origen.Replace("'", "\'"))', '@Html.Raw(ruta.Destino.Replace("'", "\'"))', '@ruta.DuracionEstimada.ToString(@"hh\:mm")', '@ruta.PrecioBase')">
                                                                <i class="bi bi-pencil-square"></i>
                                                            </button>
                                                            <form action="/Rutas/EliminarRuta" method="post" style="display:inline;">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="id" value="@ruta.Id" />
                                                                <button type="submit" class="btn btn-sm btn-outline-danger border-0"
                                                                        onclick="return confirm('¿Seguro que deseas eliminar esta ruta?')">
                                                                    <i class="bi bi-trash-fill"></i>
                                                                </button>
                                                            </form>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="6" class="text-center py-4 text-muted">
                                                    No se encontraron rutas que coincidan con la búsqueda.
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
            document.getElementById('formRuta').addEventListener('submit', function () {
                document.getElementById('inputDuracionHidden').value =
                    document.getElementById('inputDuracionVisible').value;
            });

            function editarRuta(id, nombre, origen, destino, duracion, precio) {
                document.getElementById('formTitle').innerText = "Editar Ruta";
                document.getElementById('formRuta').action = "/Rutas/Editar";
                document.getElementById('inputId').value = id;
                document.getElementById('inputNombre').value = nombre;
                document.getElementById('inputOrigen').value = origen;
                document.getElementById('inputDestino').value = destino;
                document.getElementById('inputDuracionVisible').value = duracion;
                document.getElementById('inputPrecio').value = precio;
                document.getElementById('btnSubmit').innerText = "Guardar Cambios";
                document.getElementById('btnCancelar').style.display = 'block';
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }

            function cancelarEdicion() {
                document.getElementById('formTitle').innerText = "Agregar Nueva Ruta";
                document.getElementById('formRuta').action = "/Rutas/Crear";
                document.getElementById('formRuta').reset();
                document.getElementById('inputId').value = '';
                document.getElementById('inputDuracionHidden').value = '';
                document.getElementById('btnSubmit').innerText = "Registrar Ruta";
                document.getElementById('btnCancelar').style.display = 'none';
            }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
