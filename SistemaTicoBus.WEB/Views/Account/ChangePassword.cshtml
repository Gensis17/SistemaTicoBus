@model SistemaTicoBus.WEB.Models.ChangePasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cambio de Clave - TicoBus</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
            body {
                margin: 0;
                min-height: 100vh;
                background-color: #d1d5db;
                position: relative;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                overflow: hidden;
            }

                body::before {
                    content: "";
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background-image: url('/images/fondo-bus.jpg');
                    background-size: cover;
                    background-position: center;
                    opacity: 0.15;
                    z-index: 1;
                }

            .logo-esquina {
                position: fixed;
                top: 20px;
                left: 20px;
                z-index: 10;
                width: 120px;
                height: auto;
            }

            .login-wrapper {
                position: relative;
                z-index: 5;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
            }

            .login-card {
                background: #ffffff;
                width: 100%;
                max-width: 390px;
                padding: 35px 32px;
                border-radius: 12px;
                box-shadow: 0 8px 24px rgba(0,0,0,0.1);
                text-align: center;
            }

            .logo-central {
                width: 55px;
                margin-bottom: 12px;
            }

            .titulo {
                font-size: 24px;
                font-weight: 700;
                color: #212529;
                margin-bottom: 4px;
            }

            .subtitulo {
                color: #6c757d;
                font-size: 14px;
                margin-bottom: 26px;
            }

            .form-label {
                font-size: 12px;
                font-weight: 700;
                color: #6c757d;
                text-align: left;
                display: block;
                margin-bottom: 6px;
                letter-spacing: 0.05em;
            }

            .form-control {
                border-radius: 6px;
                padding: 11px;
                font-size: 14px;
            }

                /* Campo de solo lectura — aspecto diferenciado */
                .form-control[readonly] {
                    background-color: #f1f5f9;
                    color: #475569;
                    cursor: not-allowed;
                    border-color: #cbd5e1;
                }

            .badge-usuario {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                background: #e0f2f1;
                color: #004d40;
                font-size: 11px;
                font-weight: 700;
                padding: 4px 10px;
                border-radius: 20px;
                margin-bottom: 20px;
            }

            .btn-ticobus {
                background-color: #006a62;
                color: white;
                width: 100%;
                padding: 12px;
                border: none;
                border-radius: 6px;
                font-weight: bold;
                margin-top: 8px;
                font-size: 14px;
                transition: background-color 0.2s;
            }

                .btn-ticobus:hover {
                    background-color: #004d40;
                    color: white;
                }

            .link-secondary {
                display: block;
                margin-top: 16px;
                color: #474f5e;
                font-size: 14px;
                font-weight: 600;
                text-decoration: none;
            }

                .link-secondary:hover {
                    text-decoration: underline;
                }

            .link-volver {
                display: block;
                margin-top: 8px;
                color: #006a62;
                font-size: 13px;
                font-weight: 600;
                text-decoration: none;
            }

                .link-volver:hover {
                    text-decoration: underline;
                }
    </style>
</head>
<body>
    <img src="/images/logo-ticobus.png" class="logo-esquina" alt="TicoBus Logo">

    <div class="login-wrapper">
        <div class="login-card">
            <img src="/images/logo-ticobus.png" class="logo-central" alt="Logo Central">

            <h1 class="titulo">Cambio de clave</h1>
            <p class="subtitulo">Ingrese su clave actual y la nueva clave.</p>

            @if (!string.IsNullOrEmpty(Model.Nombre))
            {
                <div class="badge-usuario">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4z" />
                    </svg>
                    @Model.Nombre
                </div>
            }

            @if (TempData["MensajeExito"] != null)
            {
                <div class="alert alert-success py-2 small text-start" role="alert">
                    @TempData["MensajeExito"]
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2 small text-start" role="alert">
                    <div asp-validation-summary="ModelOnly"></div>
                </div>
            }

            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3 text-start">
                    <label class="form-label">USUARIO</label>
                    <!-- Campo prellenado de solo lectura con el usuario de sesión -->
                    <input asp-for="Nombre" class="form-control" readonly />
                </div>

                <div class="mb-3 text-start">
                    <label asp-for="ClaveActual" class="form-label">CLAVE ACTUAL</label>
                    <input asp-for="ClaveActual" type="password" class="form-control" placeholder="Clave actual" autocomplete="current-password" />
                    <span asp-validation-for="ClaveActual" class="text-danger small"></span>
                </div>

                <div class="mb-3 text-start">
                    <label asp-for="NuevaClave" class="form-label">NUEVA CLAVE</label>
                    <input asp-for="NuevaClave" type="password" class="form-control" placeholder="Nueva clave" autocomplete="new-password" />
                    <span asp-validation-for="NuevaClave" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-ticobus">Actualizar clave</button>
            </form>

            <a href="/Account/ChoferDashboard" class="link-volver">← Volver al panel</a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>