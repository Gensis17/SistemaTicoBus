@model SistemaTicoBus.WEB.Models.ChangePasswordViewModel
@using Microsoft.AspNetCore.Http
@{
    Layout = null;
    string nombreUsuario = Context.Session.GetString("NombreUsuario") ?? "";
    string rol = Context.Session.GetString("Rol") ?? "";
    string urlVolver = rol == "Chofer" ? "/Account/ChoferDashboard"
                     : rol == "Pasajero" ? "/Account/PasajeroDashboard"
                     : "/Account/Login";
    string portalLabel = rol == "Chofer" ? "Panel de Operador" : "Portal del Pasajero";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cambio de Clave - TicoBus</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
            body {
                background-color: #f4f6f8;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                font-size: 0.875rem;
                min-height: 100vh;
            }

            /* Header igual al resto del sistema */
            .top-header {
                background-color: #112233;
                color: white;
                padding: 0.65rem 1.5rem;
            }

            /* Sidebar */
            .sidebar {
                background-color: #ffffff;
                min-height: calc(100vh - 48px);
                border-right: 1px solid #e9ecef;
            }

            .brand-title {
                color: #1a2530;
                font-size: 1.2rem;
                font-weight: 700;
            }

            .section-title {
                font-size: 0.7rem;
                text-transform: uppercase;
                letter-spacing: .05em;
                color: #9097a3;
                font-weight: 700;
            }

            .sidebar .nav-link {
                color: #5a6578;
                font-weight: 500;
                font-size: 0.82rem;
                padding: 0.65rem 1rem;
                border-radius: 0.5rem;
                margin-bottom: 0.2rem;
                display: flex;
                align-items: center;
                text-decoration: none;
            }

                .sidebar .nav-link.active {
                    background: #e0f2f1;
                    color: #004d40;
                    font-weight: 600;
                }

                .sidebar .nav-link:hover:not(.active) {
                    background: #f8f9fa;
                    color: #1a2530;
                }

            /* Contenido centrado */
            .content-area {
                background-color: #f4f6f8;
                min-height: calc(100vh - 48px);
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 2rem 1rem;
            }

            /* Card del formulario */
            .clave-card {
                background: #ffffff;
                border-radius: 1rem;
                border: 1px solid #e9ecef;
                padding: 2rem;
                width: 100%;
                max-width: 420px;
                box-shadow: 0 4px 20px rgba(0,0,0,0.06);
            }

            .clave-card-header {
                text-align: center;
                margin-bottom: 1.5rem;
                padding-bottom: 1.25rem;
                border-bottom: 1px solid #f1f3f5;
            }

            .icon-circle {
                width: 56px;
                height: 56px;
                background: linear-gradient(135deg, #006a62, #004d40);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 0.85rem;
                color: white;
                font-size: 1.4rem;
            }

            .user-badge {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                background: #e0f2f1;
                color: #004d40;
                font-size: 0.78rem;
                font-weight: 700;
                padding: 4px 12px;
                border-radius: 20px;
                margin-top: 0.5rem;
            }

            .form-label {
                font-size: 0.72rem;
                font-weight: 700;
                color: #6c757d;
                text-transform: uppercase;
                letter-spacing: 0.04em;
            }

            .form-control {
                font-size: 0.85rem;
                border-radius: 0.5rem;
                padding: 0.6rem 0.85rem;
                border: 1px solid #dee2e6;
            }

                .form-control:focus {
                    border-color: #006a62;
                    box-shadow: 0 0 0 3px rgba(0,106,98,0.12);
                }

                .form-control[readonly] {
                    background: #f1f5f9;
                    color: #475569;
                    cursor: not-allowed;
                }

            .btn-ticobus {
                background-color: #006a62;
                color: white;
                font-weight: 700;
                font-size: 0.85rem;
                border-radius: 0.5rem;
                padding: 0.7rem;
                border: none;
                width: 100%;
                transition: background-color 0.2s;
            }

                .btn-ticobus:hover {
                    background-color: #004d40;
                    color: white;
                }

            .link-volver {
                display: block;
                text-align: center;
                margin-top: 1rem;
                color: #006a62;
                font-size: 0.82rem;
                font-weight: 600;
                text-decoration: none;
            }

                .link-volver:hover {
                    text-decoration: underline;
                    color: #004d40;
                }
    </style>
</head>
<body>
    <div class="container-fluid p-0">

        <!-- Header -->
        <div class="row g-0 top-header align-items-center">
            <div class="col-6 d-flex align-items-center gap-2">
                <span class="fw-bold" style="font-size:1rem;">TicoBus</span>
                <span class="text-secondary">|</span>
                <span class="text-muted text-uppercase" style="font-size:0.68rem;letter-spacing:.05em;">@portalLabel</span>
            </div>
            <div class="col-6 text-end">
                <div class="dropdown d-inline-block">
                    <button class="btn btn-link text-white text-decoration-none dropdown-toggle p-0 d-flex align-items-center ms-auto"
                            style="font-size:0.82rem;" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-2" style="font-size:1.1rem;"></i>@nombreUsuario
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item text-danger" href="/Account/Logout">
                                <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="row g-0">
            <!-- Sidebar -->
            <div class="col-md-3 col-lg-2 p-3 sidebar d-flex flex-column justify-content-between d-none d-md-flex">
                <div>
                    <div class="mb-4 px-2">
                        <h2 class="brand-title m-0">TicoBus</h2>
                        <span class="text-muted" style="font-size:0.72rem;">@portalLabel</span>
                    </div>
                    <div class="mb-2 px-2"><span class="section-title">@(rol == "Chofer" ? "Operación" : "Mi Cuenta")</span></div>
                    <ul class="nav flex-column mb-4">
                        @if (rol == "Chofer")
                        {
                            <li><a href="/Account/ChoferDashboard" class="nav-link"><i class="bi bi-person-circle me-3"></i>Mi Perfil</a></li>
                            <li><a href="/Pasajeros/ListadoPasajeros" class="nav-link"><i class="bi bi-person-add me-3"></i>Registrar Pasajero</a></li>
                            <li><a href="/Rutas/Index" class="nav-link"><i class="bi bi-signpost-split me-3"></i>Catálogo de Rutas</a></li>
                            <li><a href="/Account/ChangePassword" class="nav-link active"><i class="bi bi-lock me-3"></i>Cambiar Clave</a></li>
                            <li><a href="#" class="nav-link"><i class="bi bi-bus-front me-3"></i>Mis Viajes</a></li>
                        }
                        else
                        {
                            <li><a href="/Account/PasajeroPerfil" class="nav-link"><i class="bi bi-person me-3"></i>Mi Perfil</a></li>
                            <li><a href="/Account/PasajeroDashboard" class="nav-link"><i class="bi bi-ticket-perforated me-3"></i>Mis Viajes</a></li>
                            <li><a href="/Account/ChangePassword" class="nav-link active"><i class="bi bi-lock me-3"></i>Cambiar Clave</a></li>
                        }
                    </ul>
                </div>
                <div>
                    <hr class="text-muted">
                    <ul class="nav flex-column">
                        <li><a href="/Account/Logout" class="nav-link text-danger"><i class="bi bi-box-arrow-right me-3"></i>Cerrar Sesión</a></li>
                    </ul>
                </div>
            </div>

            <!-- Contenido -->
            <div class="col-md-9 col-lg-10 content-area">
                <div class="clave-card">

                    <!-- Encabezado de la card -->
                    <div class="clave-card-header">
                        <div class="icon-circle">
                            <i class="bi bi-shield-lock"></i>
                        </div>
                        <h5 class="fw-bold mb-1" style="color:#1a2530;">Cambio de Clave</h5>
                        <p class="text-muted mb-0" style="font-size:0.8rem;">Ingresa tu clave actual y la nueva clave</p>
                        <div class="user-badge">
                            <i class="bi bi-person-fill"></i> @nombreUsuario
                        </div>
                    </div>

                    <!-- Alertas -->
                    @if (TempData["MensajeExito"] != null)
                    {
                        <div class="alert alert-success py-2 mb-3" style="font-size:0.82rem;border-radius:0.5rem;">
                            <i class="bi bi-check-circle me-2"></i>@TempData["MensajeExito"]
                        </div>
                    }

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2 mb-3" style="font-size:0.82rem;border-radius:0.5rem;">
                            <div asp-validation-summary="ModelOnly"></div>
                        </div>
                    }

                    <!-- Formulario -->
                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label">Usuario</label>
                            <input asp-for="Nombre" class="form-control" readonly />
                        </div>

                        <div class="mb-3">
                            <label asp-for="ClaveActual" class="form-label">Clave Actual</label>
                            <input asp-for="ClaveActual" type="password" class="form-control"
                                   placeholder="Tu clave actual" autocomplete="current-password" />
                            <span asp-validation-for="ClaveActual" class="text-danger" style="font-size:0.75rem;"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="NuevaClave" class="form-label">Nueva Clave</label>
                            <input asp-for="NuevaClave" type="password" class="form-control"
                                   placeholder="Tu nueva clave" autocomplete="new-password" />
                            <span asp-validation-for="NuevaClave" class="text-danger" style="font-size:0.75rem;"></span>
                        </div>

                        <button type="submit" class="btn btn-ticobus">
                            <i class="bi bi-check-lg me-2"></i>Actualizar Clave
                        </button>
                    </form>

                    <a href="@urlVolver" class="link-volver">← Volver al panel</a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
